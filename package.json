{
  "name": "harness-loop",
  "version": "0.1.0",
  "description": "Self-driving coding-agent harness: run → verify → loop → done or escalate",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
